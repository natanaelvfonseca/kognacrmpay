{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/crm", "destination": "/index.html" },
    { "source": "/pay", "destination": "/index.html" },
    { "source": "/crm/:path*", "destination": "/index.html" },
    { "source": "/pay/:path*", "destination": "/index.html" }
  ]
}
